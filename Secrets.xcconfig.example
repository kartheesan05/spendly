// Secrets.xcconfig.example
// Copy this file to Secrets.xcconfig and fill in real values.
// Secrets.xcconfig is gitignored and never committed.
//
// After rotating/regenerating your Notion integration token in
// Notion > Settings > Connections, paste it below in the COPY.

NOTION_TOKEN = your_notion_integration_token_here
NOTION_DATABASE_ID = your_notion_database_id_here
